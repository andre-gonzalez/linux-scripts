#!/bin/sh
# Watch for HDMI hotplug events and switch the screen layout automatically:
#   HDMI connected    -> dual-screen-layout (ultrawide + laptop, ultra dwm)
#   HDMI disconnected -> one-screen-layout  (laptop only, laptop dwm)
#
# Started in the background from ~/.xinitrc so it lives inside the X session
# (inherits DISPLAY/XAUTHORITY) and survives dwm restarts (.xinitrc runs dwm in
# a loop). The layout scripts rebuild/restart dwm via cdwm, which runs
# "sudo make clean install" -- see /etc/sudoers.d/dwm-rebuild for the
# passwordless rule that lets this work unattended.

LAYOUT_DUAL="$HOME/.scripts/dual-screen-layout"
LAYOUT_ONE="$HOME/.scripts/one-screen-layout"

hdmi_connected() {
	xrandr --query 2>/dev/null | grep -qE '^HDMI[A-Za-z0-9-]* connected'
}

current_state() {
	if hdmi_connected; then
		echo dual
	else
		echo one
	fi
}

apply() {
	new=$(current_state)
	[ "$new" = "$state" ] && return
	state=$new
	if [ "$new" = dual ]; then
		"$LAYOUT_DUAL"
	else
		"$LAYOUT_ONE"
	fi
}

# Seed the state from what is connected now, without running a layout, so we
# don't trigger a dwm rebuild on every login -- only on an actual change.
state=$(current_state)

# Force line buffering so events reach the loop immediately through the pipe.
stdbuf -oL udevadm monitor --udev --subsystem-match=drm 2>/dev/null | while read -r line; do
	case "$line" in
	*change*)
		# Give the kernel a moment to update connector status before reading it.
		sleep 1
		apply
		;;
	esac
done
